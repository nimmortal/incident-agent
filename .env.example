# Mandatory LLM provider. Use a Copilot-compatible token, not a classic ghp_* PAT.
# Supported examples: gho_* OAuth/device-flow token, ghu_* GitHub App token, or a
# user-owned github_pat_* fine-grained PAT with Account > Copilot Requests permission.
COPILOT_GITHUB_TOKEN=
# Hermes image patch defaults this to copilot-developer-cli for PAT-compatible Copilot calls.
COPILOT_INTEGRATION_ID=copilot-developer-cli

# Optional Jira/JSM source for tickets and incident polling.
JIRA_PROJECT_KEY=JSM
JIRA_POLL_INTERVAL_SECONDS=300
JIRA_POLL_BATCH_SIZE=3
JIRA_JQL="project = JSM AND statusCategory != Done AND (labels is EMPTY OR labels not in (ai-investigated, ai-investigating)) ORDER BY created ASC"

# Jira/JSM access should be provided to Hermes through MCP, not through this wrapper.
JIRA_MCP_URL=
# Use Bearer for MCP-issued tokens, or Basic when JIRA_MCP_TOKEN is base64(email:api-token).
JIRA_MCP_AUTH_SCHEME=Bearer
JIRA_MCP_TOKEN=

# Optional GitHub source for code, deployments, PRs, and workflow runs.
GITHUB_TOKEN=
# Alternative to GITHUB_TOKEN: generate a short-lived GitHub App installation token at runtime.
GITHUB_APP_ID=
# Optional selector when the app has more than one installation.
GITHUB_APP_INSTALLATION_ACCOUNT=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_REPOSITORY=
# Prefer a mounted PEM file path or base64 to avoid newline escaping.
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_PRIVATE_KEY_BASE64=
# Inline fallback: use escaped newlines: -----BEGIN...-----\n...\n-----END...-----
GITHUB_APP_PRIVATE_KEY=

# Optional Coralogix source for logs, metrics, traces, alerts, and incidents.
CX_API_KEY=
CX_REGION=

# Optional Postgres source for read-only incident evidence.
DATABASE_URL=

HERMES_BIN=hermes
HERMES_ARGS="chat --quiet -q"
HERMES_CONFIG_TEMPLATE=config/hermes.config.yaml
HERMES_RUNTIME_HOME=data/hermes-home
HERMES_SKILLS_SEED_HOME=/opt/hermes-seed-home
HERMES_LOCAL_SKILLS_PATH=skills
HERMES_TIMEOUT_SECONDS=900
# Optional reasoning controls passed to Hermes config.
# Effort values: none, minimal, low, medium, high, xhigh. Empty uses Hermes default.
HERMES_REASONING_EFFORT=
HERMES_SHOW_REASONING=false
HERMES_REASONING_FULL=false
# Optional subagent delegation controls. Subagents are autonomous; keep dangerous
# command auto-approval off unless the runtime is fully trusted.
HERMES_DELEGATION_MODEL=
HERMES_DELEGATION_PROVIDER=
HERMES_DELEGATION_REASONING_EFFORT=
HERMES_DELEGATION_MAX_ITERATIONS=30
HERMES_DELEGATION_CHILD_TIMEOUT_SECONDS=600
HERMES_DELEGATION_MAX_CONCURRENT_CHILDREN=2
HERMES_DELEGATION_MAX_ASYNC_CHILDREN=2
HERMES_DELEGATION_MAX_SPAWN_DEPTH=1
HERMES_DELEGATION_SUBAGENT_AUTO_APPROVE=false
